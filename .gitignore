.ipynb_checkpoints/
*.ipynb

# ── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp

# ── Theory (internal derivations, not for public repo) ───────────────────────
Theory/

# --manuscript
manuscript/

# slurm job output / error logs
*.out.*
*.err.*

# examples
examples/

# qe scratch
qe_scratch/

