sqtc_*_run/

# ── SLURM job output ──────────────────────────────────────────────────────────
job.err.*
job.out.*

# ── Generated plots and large data at repo root ───────────────────────────────
*.png
*.pdf
*.npz

# Allow plots that live inside codes/ (e.g. test reference images)
!codes/**/*.png
!codes/**/*.pdf

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

