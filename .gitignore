# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environment ───────────────────────────────────────────────────────
.venv/
venv/
env/

# ── VASP calculation run directories ─────────────────────────────────────────
